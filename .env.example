# Copy this file to .env and enter the values from your SkyPrep account.
# Never place either value in the HTML file or commit your real .env file.
SKYPREP_API_KEY=replace_with_your_private_api_key
SKYPREP_ACCOUNT_KEY=vincentianuniversity.org
# Optional fallback IDs. The app normally discovers the newest completed
# reports with the configured HSI report names.
SKYPREP_USERS_REPORT_ID=576212
SKYPREP_COURSES_REPORT_ID=576211
# Optional. Set this in production to require a dashboard access code.
DASHBOARD_ACCESS_CODE=
# Optional. Use a long random value in production to sign dashboard sessions.
DASHBOARD_SESSION_SECRET=
PORT=3000
